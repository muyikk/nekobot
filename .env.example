# NekoBot QQ 机器人配置文件
# 复制此文件为 .env 并填入真实配置

# ==================== Bot 配置 ====================
BOT_UIN=你的QQ号
ROOT=管理员QQ号
WS_URI=ws://你的NapCat地址:端口
TOKEN=你的NapCat令牌（可选）

# ==================== AI API 配置 ====================
# 主要 AI API (MiniMax)
API_KEY=你的MiniMax_API_KEY
BASE_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2
MODEL=MiniMax-M2.7

# SiliconFlow API (备用)
SILICON_API_KEY=你的SiliconFlow_API_KEY

# ==================== Web 配置 ====================
WEB_PASSWORD=你的Web界面密码

# ==================== 聊天配置 ====================
MAX_HISTORY_LENGTH=50

# ==================== 图片识别配置 ====================
PIC_MODEL=zai-org/GLM-4.6V

# ==================== 缓存配置 ====================
CACHE_ADDRESS=/path/to/cache/directory

# ==================== 语音配置 ====================
VOICE=fnlp/MOSS-TTSD-v0.5:diana

# ==================== 搜索配置 ====================
SEARCH_API_KEY=你的搜索API密钥
SEARCH_API_URL=你的搜索API地址

# ==================== 视频配置 ====================
VIDEO_API_KEY=你的视频API密钥

# ==================== GitHub 配置 ====================
GF_API_KEY=你的GitHub_API密钥

# ==================== PDF 配置 ====================
PDF_API_KEY=你的PDF_API密钥
